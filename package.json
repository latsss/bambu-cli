{
  "name": "bambu-cli",
  "version": "1.1.1",
  "description": "CLI tool to interact with Bambu Lab printers in LAN/LAN+dev mode",
  "main": "index.js",
  "bin": {
    "bambu-cli": "./index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "WTFPL",
  "scripts": {
    "bundle": "esbuild index.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist/bambu-cli.cjs --legal-comments=none",
    "build:sea": "bash scripts/build-sea.sh",
    "clean": "rm -rf dist sea-prep.blob"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.5",
    "basic-ftp": "^6.0.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "jszip": "^3.10.1",
    "mqtt": "^5.13.1",
    "pngjs": "^7.0.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
